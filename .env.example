# LLM provider — any OpenAI-compatible endpoint. Defaults to NVIDIA NIM.
# Get a free key at https://build.nvidia.com (open a model -> "Get API Key").
LLM_API_KEY=your_nvidia_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=openai/gpt-oss-20b

# Optional tuning
# REASONING_EFFORT=low        # gpt-oss models only
# MAX_AGENT_STEPS=12
# LLM_TEMPERATURE=0.1

# Paths (defaults are fine for docker compose)
DATA_MARKDOWN_DIR=data/markdown
DATA_PROCESSED_DIR=data/processed
WORKSPACE_DIR=workspace/sessions
